[
  {
    "text": "吾辈是猫。名字尚无。",
    "author": "夏目漱石",
    "work": "《我是猫》",
    "translator": "刘振瀛"
  },
  {
    "text": "它要是高兴，能比谁都温柔可亲。",
    "author": "老舍",
    "work": "《猫》"
  },
  {
    "text": "我的爱与厌都不能成纯。",
    "author": "周作人",
    "work": "《雨天的书》"
  },
  {
    "text": "在镜中，另一只虎。",
    "author": "博尔赫斯",
    "work": "《老虎的金黄》",
    "translator": "王央乐"
  },
  {
    "text": "它能听见你听不见的声音。",
    "author": "张爱玲",
    "work": "《华丽缘》"
  }
]
